<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Launcher.App.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml"/>
        <StyleInclude Source="avares://Launcher.App/Styles/LauncherStyles.axaml"/>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml"/>
                <ResourceInclude Source="avares://Launcher.App/Styles/LauncherColors.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
