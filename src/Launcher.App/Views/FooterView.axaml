<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:Avalonia.Automation;assembly=Avalonia.Controls"
             x:Class="Launcher.App.Views.FooterView">
    <Grid Margin="0,12,0,0" MinHeight="34">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Classes="label footerLabel"
                       IsVisible="{Binding IsFooterMetaHintVisible}"
                       Text="ENTER select meta command" />

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsFooterIdeOptionsVisible}">
                <TextBlock Classes="label footerLabel"
                           Text="Default" />
                <ItemsControl ItemsSource="{Binding DefaultIdeOptionItems}"
                              Margin="6,0,0,0"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="option"
                                    Click="OnIdeOptionClicked"
                                    Tag="{Binding LaunchToken}"
                                    IsEnabled="{Binding IsEnabled}"
                                    automation:AutomationProperties.Name="{Binding ToolName}"
                                    ToolTip.Tip="{Binding ToolName}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SlotLabel}"
                                               FontSize="12"
                                               Foreground="{DynamicResource AccentMutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0" />
                                    <Border BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="1"
                                            Margin="0,0,1,0">
                                        <Grid Width="12" Height="12" VerticalAlignment="Center">
                                            <Image Source="{Binding ToolIcon}"
                                                   Width="12"
                                                   Height="12"
                                                   Stretch="Fill" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Width="1"
                        Height="16"
                        Margin="6,0"
                        Background="{DynamicResource ChromeBorderBrush}"
                        Opacity="0.45"
                        VerticalAlignment="Center" />

                <TextBlock Classes="label footerLabel"
                           Text="{Binding AlternativeLaunchModifierLabelText}" />
                <ItemsControl ItemsSource="{Binding AlternateIdeOptionItems}"
                              Margin="6,0,0,0"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="option"
                                    Click="OnIdeOptionClicked"
                                    Tag="{Binding LaunchToken}"
                                    IsEnabled="{Binding IsEnabled}"
                                    automation:AutomationProperties.Name="{Binding ToolName}"
                                    ToolTip.Tip="{Binding ToolName}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SlotLabel}"
                                               FontSize="12"
                                               Foreground="{DynamicResource AccentMutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,2,0" />
                                    <Border BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="1"
                                            Margin="0,0,1,0">
                                        <Grid Width="12" Height="12" VerticalAlignment="Center">
                                            <Image Source="{Binding ToolIcon}"
                                                   Width="12"
                                                   Height="12"
                                                   Stretch="Fill" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <TextBlock Classes="label footerLabel"
                       IsVisible="{Binding IsFooterTerminalHintVisible}"
                       Text="ENTER run command" />

            <TextBlock Classes="label footerLabel"
                       IsVisible="{Binding IsFooterAiHintVisible}"
                       Text="ENTER send AI prompt | Shift+Enter newline" />

            <TextBlock Classes="label footerLabel"
                       IsVisible="{Binding IsFooterFilePickerHintVisible}"
                       Text="ENTER open file | ESC back" />
        </Grid>

        <StackPanel Grid.Column="1"
                    Margin="12,0,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="2">
            <TextBlock Classes="muted"
                       IsVisible="{Binding IsFooterStatusVisible}"
                       HorizontalAlignment="Right"
                       MaxLines="1"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       Text="{Binding StatusText}" />
        </StackPanel>
    </Grid>
</UserControl>
