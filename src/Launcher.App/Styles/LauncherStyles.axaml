<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia">

    <Style Selector="Border.chrome">
        <Setter Property="Background" Value="{DynamicResource ChromeBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="Border.aiResponseCard">
        <Setter Property="Background" Value="{DynamicResource MarkdownPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MarkdownPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ScrollViewer.aiMarkdownScroll">
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollBarVisibility" Value="Visible" />
    </Style>

    <Style Selector="md|MarkdownRenderer.aiMarkdown md|MarkdownTextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text,Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="LineHeight" Value="21" />
    </Style>

    <Style Selector="md|MarkdownRenderer.aiMarkdown md|CodeBlock">
        <Setter Property="IsCodeWrapped" Value="True" />
        <Setter Property="Margin" Value="0,8,0,10" />
    </Style>

    <Style Selector="Border.searchFrame">
        <Setter Property="Background" Value="{DynamicResource SearchFrameBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SearchFrameBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,6,8,6" />
    </Style>

    <Style Selector="Border.searchFrame:focus-within">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BoxShadow" Value="0 0 0 2 #284B6BFF" />
    </Style>

    <Style Selector="Border.searchFrame.busyReject">
        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
        <Setter Property="Background" Value="#26BA3228" />
    </Style>

    <Style Selector="Border.searchFrame.busyReject TextBox.searchInput">
        <Setter Property="Background" Value="#22BA3228" />
    </Style>

    <Style Selector="Border.searchPrefix">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="Background" Value="{DynamicResource SearchPrefixBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SearchPrefixBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5,5,5,5" />
        <Setter Property="Padding" Value="0,0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Left" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.searchPrefixText">
        <Setter Property="Foreground" Value="{DynamicResource AccentMutedBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Emoji,Segoe Fluent Icons,Segoe UI Symbol,Segoe UI" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.searchHintText">
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text,Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.searchHintSeparator">
        <Setter Property="Foreground" Value="{DynamicResource SearchHintSeparatorBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Margin" Value="8,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.searchHintButton">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="Cascadia Mono,Consolas" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="IsTabStop" Value="False" />
    </Style>

    <Style Selector="Button.searchHintButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource OptionHoverBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="Button.searchHintButton:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="TextBlock.sectionTitle">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.label">
        <Setter Property="Foreground" Value="{DynamicResource AccentMutedBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="Cascadia Mono,Consolas" />
    </Style>

    <Style Selector="TextBlock.footerLabel">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="TextBlock.path">
        <Setter Property="FontFamily" Value="Cascadia Mono,Consolas" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.rowProject">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.rowLineText">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style Selector="TextBox.field">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.field:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="TextBox.fieldError">
        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
    </Style>

    <Style Selector="Button.ghostButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AccentMutedBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.ghostButton:pointerover /template/ ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
    </Style>

    <Style Selector="TextBox.searchInput">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,0,8,0" />
        <Setter Property="FontSize" Value="19" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="ComboBox.field">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,0" />
    </Style>

    <Style Selector="ComboBox.field:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.option">
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Background" Value="{DynamicResource OptionBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="FontFamily" Value="Cascadia Mono,Consolas" />
    </Style>

    <Style Selector="Button.option TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.option:pointerover">
        <Setter Property="Background" Value="{DynamicResource OptionHoverBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.option:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.option:disabled">
        <Setter Property="Opacity" Value="0.55" />
    </Style>

    <Style Selector="Button.chromeAction">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Background" Value="{DynamicResource ChromeActionBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="Cascadia Mono,Consolas" />
    </Style>

    <Style Selector="Button.chromeAction:pointerover">
        <Setter Property="Background" Value="{DynamicResource ChromeActionHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.primaryButton">
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.secondaryButton">
        <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SecondaryButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="ListBox.results">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style Selector="ListBox.results:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="ListBox.results > ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.results > ListBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource ResultHoverBrush}" />
    </Style>

    <Style Selector="ListBox.results > ListBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
    </Style>

    <Style Selector="Border.rowShell">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderBrush" Value="{DynamicResource RowBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="MinHeight" Value="38" />
    </Style>

    <Style Selector="TextBlock.terminalRowText">
        <Setter Property="FontFamily" Value="Cascadia Mono,Consolas" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="CheckBox.onboardingOption">
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="StackPanel.onboardingActions">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Spacing" Value="8" />
    </Style>

</Styles>
